{
    "name": "@charleston/design-system",
    "version": "0.1.11",
    "private": false,
    "description": "Charleston Design System for React Web",
    "main": "./dist/index.cjs",
    "types": "./dist/index.d.cts",
    "packageManager": "pnpm@10.13.1",
    "exports": {
        ".": {
            "react-web": {
                "types": "./dist/index.d.cts",
                "default": "./dist/index.cjs"
            },
            "default": {
                "types": "./dist/index.d.cts",
                "default": "./dist/index.cjs"
            }
        }
    },
    "files": [
        "dist"
    ],
    "publishConfig": {
        "access": "restricted"
    },
    "scripts": {
        "build": "tsdown",
        "dev": "tsdown --watch",
        "lint": "eslint .",
        "typecheck": "tsc --noEmit",
        "prepublishOnly": "npm run build",
        "format": "prettier . --write",
        "prepare": "husky",
        "test": "echo \"No tests specified\" && exit 0",
        "publish:local": "npm publish --registry http://localhost:4873"
    },
    "peerDependencies": {
        "react": ">=18"
    },
    "dependencies": {
      "react": "^19.2.1"
    },
    "devDependencies": {
        "@trivago/prettier-plugin-sort-imports": "^6.0.2",
        "@types/react": "^19.2.0",
        "@typescript-eslint/eslint-plugin": "^8.53.0",
        "@typescript-eslint/parser": "^8.53.0",
        "eslint": "^10.2.1",
        "eslint-plugin-import": "^2.32.0",
        "eslint-plugin-react": "^7.37.5",
        "eslint-plugin-react-hooks": "^7.0.1",
        "husky": "^9.1.7",
        "lint-staged": "^16.2.7",
        "prettier": "^3.8.0",
        "tsdown": "^0.20.3",
        "typescript": "^5.9.3"
    },
    "lint-staged": {
        "*.{ts,tsx,js,jsx}": [
            "prettier --write",
            "eslint --fix"
        ]
    }
}
